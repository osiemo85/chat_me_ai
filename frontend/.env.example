# Backend origin used by the Next.js server and server-rendered fetches.
API_BASE_URL=http://localhost:8000

# Optional: expose a direct browser-to-backend URL. Leave blank to use the
# same-origin Next.js `/api/v1/*` proxy configured in `next.config.ts`.
NEXT_PUBLIC_API_BASE_URL=
GOOGLE_CLIENT_ID=
NEXTAUTH_URL=http://localhost:3000
