# Monorepo-wide ignore rules for backend, frontend, local tooling, and uploads.

# OS / editor noise
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/

# Environment and secrets
.env
.env.*
!.env.example
!.env.*.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Python
__pycache__/
*.py[cod]
*.pyd
*.so
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pyre/
.cache/
coverage.xml
pip-wheel-metadata/

# Python virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/
backend/venv/

# Python packaging / build outputs
build/
dist/
site/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# Node / frontend
node_modules/
.npm/
.pnpm-store/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
*.tsbuildinfo

# Frontend logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Deployment / hosting
.vercel/
.turbo/

# Local databases / runtime artifacts
*.db
*.sqlite
*.sqlite3
*.pid
*.pid.lock

# Uploaded files and generated local storage artifacts
storage/cvs/*
storage/passport_photos/*
storage/audio/*
!storage/cvs/.gitkeep
!storage/passport_photos/.gitkeep
!storage/audio/.gitkeep

# Temp files
tmp/
temp/
*.tmp

# Logs
*.log
logs/

# Misc generated assets
*.pem
